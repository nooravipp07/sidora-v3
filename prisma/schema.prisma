// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// User Model
model User {
  id              Int       @id @default(autoincrement())
  name            String
  email           String    @unique
  namaLengkap     String?
  noTelepon       String?
  emailVerifiedAt DateTime?
  password        String
  rememberToken   String?   @db.VarChar(100)
  roleId          Int?
  jenisAkun       Int?
  kecamatanId     Int?
  desaKelurahanId Int?
  status          Int?      @default(0)
  lastLogin       DateTime?
  createdAt       DateTime? @default(now())
  updatedAt       DateTime? @updatedAt

  // Relations
  role          Role?          @relation(fields: [roleId], references: [id])
  kecamatan     Kecamatan?     @relation(fields: [kecamatanId], references: [id])
  refreshTokens RefreshToken[]
  loginHistory  LoginHistory[]

  @@map("m_users")
}

// Role Model
model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  // Relations
  users       User[]
  permissions RolePermission[]

  @@map("m_roles")
}

// Permission Model
model Permission {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  // Relations
  roles RolePermission[]

  @@map("m_permissions")
}

// Role Permission Pivot Model
model RolePermission {
  id           Int @id @default(autoincrement())
  roleId       Int
  permissionId Int

  // Relations
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("m_role_permissions")
}

// Refresh Token Model for token rotation
model RefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("m_refresh_tokens")
}

// Login History Model for audit trail
model LoginHistory {
  id        Int       @id @default(autoincrement())
  userId    Int
  ipAddress String?
  userAgent String?
  loginAt   DateTime  @default(now())
  logoutAt  DateTime?
  status    String    @default("success") // success, failed, etc

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("m_login_history")
}

// Kecamatan (District) Model
model Kecamatan {
  id        Int       @id @default(autoincrement())
  nama      String
  latitude  String?
  longitude String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  desaKelurahanList DesaKelurahan[]
  Registration      Registration[]
  users             User[]

  @@map("m_kecamatan")
}

// Desa/Kelurahan Model
model DesaKelurahan {
  id          Int       @id @default(autoincrement())
  kecamatanId Int
  nama        String    @db.VarChar(150)
  tipe        String    @db.VarChar(20) // 'desa' or 'kelurahan'
  latitude    String?   @db.VarChar(50)
  longitude   String?   @db.VarChar(50)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  kecamatan             Kecamatan               @relation(fields: [kecamatanId], references: [id], onDelete: Cascade)
  facilityRecords       FacilityRecord[]
  equipment             Equipment[]
  sportsGroups          SportsGroup[]
  athletes              Athlete[]
  EquipmentStaging      EquipmentStaging[]
  FacilityRecordStaging FacilityRecordStaging[]
  AthleteStaging        AthleteStaging[]
  SportsGroupStaging    SportsGroupStaging[]

  @@index([kecamatanId])
  @@map("m_desa_kelurahan")
}

// Cabang Olahraga (Sport Branch) Model
model CabangOlahraga {
  id        Int       @id @default(autoincrement())
  nama      String    @db.VarChar(100)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  athletes       Athlete[]
  AthleteStaging AthleteStaging[]

  @@map("m_cabang_olahraga")
}

// Sarana (Facility) Model
model Sarana {
  id        Int       @id @default(autoincrement())
  nama      String    @db.VarChar(150)
  jenis     String?   @db.VarChar(100)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  equipment        Equipment[]
  EquipmentStaging EquipmentStaging[]

  @@map("m_sarana")
}

// Prasarana (Infrastructure) Model
model Prasarana {
  id        Int       @id @default(autoincrement())
  nama      String    @db.VarChar(150)
  jenis     String?   @db.VarChar(100)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  facilityRecords       FacilityRecord[]
  FacilityRecordStaging FacilityRecordStaging[]

  @@map("m_prasarana")
}

model News {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  content     String    @db.LongText
  thumbnail   String?
  author      String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  categoryId  Int?
  views       Int       @default(0)
  category    Category? @relation(fields: [categoryId], references: [id])
  tags        NewsTag[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@map("news")
}

model Category {
  id   Int    @id @default(autoincrement())
  name String
  slug String @unique

  news News[]

  @@map("categories")
}

model Tag {
  id   Int    @id @default(autoincrement())
  name String

  news NewsTag[]

  @@map("tags")
}

model NewsTag {
  newsId Int
  tagId  Int

  news News @relation(fields: [newsId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([newsId, tagId])
  @@map("news_tags")
}

model Gallery {
  id          Int     @id @default(autoincrement())
  title       String
  description String?

  items GalleryItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("galleries")
}

model GalleryItem {
  id        Int     @id @default(autoincrement())
  galleryId Int
  imageUrl  String
  caption   String?

  gallery Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("gallery_items")
}

model Agenda {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  location    String?
  category    String? // e.g., "Kompetisi", "Pelatihan", "Event Komunitas", "Acara"
  level       String? // e.g., "Lokal", "Daerah", "Regional", "Nasional"
  status      String  @default("Active") // "Active" or "Inactive"

  startDate DateTime
  endDate   DateTime?
  isAllDay  Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("agendas")
}

// Visitor Model for tracking page views and visitor statistics
model Visitor {
  id        Int      @id @default(autoincrement())
  sessionId String   @db.VarChar(100) // Unique session identifier
  ipAddress String?  @db.VarChar(50)
  userAgent String?  @db.Text
  page      String   @db.VarChar(255) // Page path (e.g., /berita, /galeri, /)
  referrer  String?  @db.VarChar(255) // Referrer URL
  visitedAt DateTime @default(now())

  // For better analytics
  country    String? @db.VarChar(100)
  city       String? @db.VarChar(100)
  deviceType String? @db.VarChar(50) // desktop, mobile, tablet

  @@index([sessionId])
  @@index([visitedAt])
  @@index([page])
  @@map("visitors")
}

model FacilityRecord {
  id              Int @id @default(autoincrement())
  desaKelurahanId Int
  prasaranaId     Int
  year            Int

  condition       String?
  ownershipStatus String? // OWNED, RENTED, SHARED
  address         String?

  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  prasarana     Prasarana             @relation(fields: [prasaranaId], references: [id])
  desaKelurahan DesaKelurahan         @relation(fields: [desaKelurahanId], references: [id])
  photos        FacilityRecordPhoto[]

  @@unique([prasaranaId, year])
  @@index([year])
  @@index([prasaranaId])
  @@map("facility_record")
}

model FacilityRecordPhoto {
  id               Int @id @default(autoincrement())
  facilityRecordId Int

  fileUrl  String
  fileName String?
  fileSize Int?
  mimeType String?

  photoType   String?
  description String?

  takenAt    DateTime?
  uploadedAt DateTime  @default(now())
  uploadedBy String?

  isPrimary Boolean @default(false)

  latitude  Float?
  longitude Float?

  facilityRecord FacilityRecord @relation(fields: [facilityRecordId], references: [id])

  @@index([facilityRecordId])
  @@map("facility_record_photo")
}

model Equipment {
  id Int @id @default(autoincrement())

  desaKelurahanId Int
  saranaId        Int

  quantity Int     @default(0)
  unit     String? @db.VarChar(50)

  isUsable          Boolean @default(true)
  isGovernmentGrant Boolean @default(false)

  year Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  desaKelurahan DesaKelurahan @relation(fields: [desaKelurahanId], references: [id], onDelete: Cascade)
  sarana        Sarana        @relation(fields: [saranaId], references: [id], onDelete: Cascade)

  @@index([desaKelurahanId])
  @@index([saranaId])
  @@index([year])
  @@map("equipments")
}

model SportsGroup {
  id Int @id @default(autoincrement())

  desaKelurahanId Int

  groupName  String  @db.VarChar(150)
  leaderName String? @db.VarChar(150)

  memberCount Int @default(0)

  isVerified Boolean @default(false)

  decreeNumber       String? @db.VarChar(100) // nomor SK
  secretariatAddress String? @db.VarChar(255)

  year Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  desaKelurahan DesaKelurahan @relation(fields: [desaKelurahanId], references: [id], onDelete: Cascade)

  @@index([desaKelurahanId])
  @@index([year])
  @@map("sports_groups")
}

model Athlete {
  id Int @id @default(autoincrement())

  nationalId String    @unique @db.VarChar(20) // NIK
  fullName   String    @db.VarChar(150)
  birthPlace String?   @db.VarChar(100)
  birthDate  DateTime?
  gender     String?   @db.VarChar(10)

  desaKelurahanId Int

  fullAddress  String?
  organization String? @db.VarChar(150)
  category     String? @db.VarChar(100)
  status       String  @default("aktif") @db.VarChar(20) // aktif, non-aktif

  sportId  Int?
  photoUrl String? @db.VarChar(255)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  desaKelurahan DesaKelurahan        @relation(fields: [desaKelurahanId], references: [id], onDelete: Cascade)
  sport         CabangOlahraga?      @relation(fields: [sportId], references: [id])
  achievements  AthleteAchievement[]

  @@index([desaKelurahanId])
  @@index([sportId])
  @@map("athletes")
}

model AthleteAchievement {
  id Int @id @default(autoincrement())

  athleteId Int

  achievementName String  @db.VarChar(150)
  category        String? @db.VarChar(100)

  medal String? @db.VarChar(20)
  year  Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  athlete Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@index([athleteId])
  @@map("athlete_achievements")
}

model Registration {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String

  // informasi tambahan
  nip         String
  namaLengkap String
  noTelepon   String

  // jenis pendaftar
  jenisAkun Int // 1 = Kecamatan, 2 = Lembaga

  // jika kecamatan
  kecamatanId Int

  // jika lembaga
  lembagaId Int?

  // status workflow
  status Int // 1 = PENDING, 2 = APPROVE, 3 = REJECT

  // verifikasi
  verifiedBy Int
  verifiedAt DateTime?

  // alasan reject
  rejectReason String?

  docUrl String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kecamatan Kecamatan @relation(fields: [kecamatanId], references: [id])

  @@map("registrations")
}

enum StagingStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StagingAction {
  CREATE
  UPDATE
  DELETE
}

model EquipmentStaging {
  id Int @id @default(autoincrement())

  desaKelurahanId Int
  saranaId        Int

  quantity Int     @default(0)
  unit     String? @db.VarChar(50)

  isUsable          Boolean @default(true)
  isGovernmentGrant Boolean @default(false)

  year Int?

  // staging
  actionType  StagingAction
  referenceId Int? // id dari Equipment

  status StagingStatus @default(PENDING)

  submittedBy     String
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  desaKelurahan DesaKelurahan @relation(fields: [desaKelurahanId], references: [id])
  sarana        Sarana        @relation(fields: [saranaId], references: [id])

  @@index([status])
  @@index([desaKelurahanId])
  @@index([year])
  @@map("equipment_staging")
}

model FacilityRecordStaging {
  id Int @id @default(autoincrement())

  desaKelurahanId Int
  prasaranaId     Int
  year            Int

  condition       String?
  ownershipStatus String?
  address         String?
  notes           String?
  isActive        Boolean @default(true)

  // staging
  actionType  StagingAction
  referenceId Int?

  status StagingStatus @default(PENDING)

  submittedBy     String
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  desaKelurahan DesaKelurahan @relation(fields: [desaKelurahanId], references: [id])
  prasarana     Prasarana     @relation(fields: [prasaranaId], references: [id])

  photos FacilityRecordPhotoStaging[]

  @@index([status])
  @@index([desaKelurahanId])
  @@index([year])
  @@map("facility_record_staging")
}

model FacilityRecordPhotoStaging {
  id Int @id @default(autoincrement())

  facilityRecordStagingId Int

  fileUrl  String
  fileName String?
  fileSize Int?
  mimeType String?

  photoType   String?
  description String?

  takenAt    DateTime?
  uploadedBy String?

  isPrimary Boolean @default(false)

  latitude  Float?
  longitude Float?

  createdAt DateTime @default(now())

  facilityRecordStaging FacilityRecordStaging @relation(fields: [facilityRecordStagingId], references: [id], onDelete: Cascade)

  @@index([facilityRecordStagingId])
  @@map("facility_record_photo_staging")
}

model AthleteStaging {
  id Int @id @default(autoincrement())

  nationalId String @db.VarChar(20)
  fullName   String @db.VarChar(150)

  birthPlace String?   @db.VarChar(100)
  birthDate  DateTime?
  gender     String?   @db.VarChar(10)

  desaKelurahanId Int

  fullAddress   String?
  organization  String? @db.VarChar(150)
  category      String? @db.VarChar(100)
  statusAthlete String  @default("aktif")

  sportId  Int?
  photoUrl String?

  // staging
  actionType  StagingAction
  referenceId Int?

  status StagingStatus @default(PENDING)

  submittedBy     String
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  achievements AthleteAchievementStaging[]

  desaKelurahan DesaKelurahan   @relation(fields: [desaKelurahanId], references: [id])
  sport         CabangOlahraga? @relation(fields: [sportId], references: [id])

  @@index([status])
  @@index([desaKelurahanId])
  @@index([sportId])
  @@map("athlete_staging")
}

model AthleteAchievementStaging {
  id Int @id @default(autoincrement())

  athleteStagingId Int

  achievementName String
  category        String?

  medal String?
  year  Int?

  createdAt DateTime @default(now())

  athlete AthleteStaging @relation(fields: [athleteStagingId], references: [id], onDelete: Cascade)

  @@index([athleteStagingId])
  @@map("athlete_achievement_staging")
}

model SportsGroupStaging {
  id Int @id @default(autoincrement())

  desaKelurahanId Int

  groupName  String
  leaderName String?

  memberCount Int @default(0)

  isVerified Boolean @default(false)

  decreeNumber       String?
  secretariatAddress String?

  year Int?

  // staging
  actionType  StagingAction
  referenceId Int?

  status StagingStatus @default(PENDING)

  submittedBy     String
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  desaKelurahan DesaKelurahan @relation(fields: [desaKelurahanId], references: [id])

  @@index([status])
  @@index([desaKelurahanId])
  @@index([year])
  @@map("sports_group_staging")
}

model StagingLog {
  id Int @id @default(autoincrement())

  entityType String
  stagingId  Int

  action String // SUBMIT, APPROVE, REJECT
  actor  String

  note String?

  createdAt DateTime @default(now())

  @@index([entityType, stagingId])
  @@map("staging_logs")
}
