generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int            @id @default(autoincrement())
  name            String
  email           String         @unique
  namaLengkap     String?
  noTelepon       String?
  emailVerifiedAt DateTime?
  password        String
  rememberToken   String?        @db.VarChar(100)
  roleId          Int?
  jenisAkun       Int?
  kecamatanId     Int?
  desaKelurahanId Int?
  status          Int?           @default(0)
  lastLogin       DateTime?
  createdAt       DateTime?      @default(now())
  updatedAt       DateTime?      @updatedAt
  loginHistory    LoginHistory[]
  refreshTokens   RefreshToken[]
  kecamatan       Kecamatan?     @relation(fields: [kecamatanId], references: [id])
  role            Role?          @relation(fields: [roleId], references: [id])

  @@index([kecamatanId], map: "m_users_kecamatanId_fkey")
  @@index([roleId], map: "m_users_roleId_fkey")
  @@map("m_users")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  permissions RolePermission[]
  users       User[]

  @@map("m_roles")
}

model Permission {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  roles       RolePermission[]

  @@map("m_permissions")
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId], map: "m_role_permissions_permissionId_fkey")
  @@map("m_role_permissions")
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "m_refresh_tokens_userId_fkey")
  @@map("m_refresh_tokens")
}

model LoginHistory {
  id        Int       @id @default(autoincrement())
  userId    Int
  ipAddress String?
  userAgent String?
  loginAt   DateTime  @default(now())
  logoutAt  DateTime?
  status    String    @default("success")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "m_login_history_userId_fkey")
  @@map("m_login_history")
}

model Kecamatan {
  id                Int             @id @default(autoincrement())
  nama              String
  latitude          String?
  longitude         String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  desaKelurahanList DesaKelurahan[]
  users             User[]
  Registration      Registration[]

  @@map("m_kecamatan")
}

model DesaKelurahan {
  id                    Int                     @id @default(autoincrement())
  kecamatanId           Int
  nama                  String                  @db.VarChar(150)
  tipe                  String                  @db.VarChar(20)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  deletedAt             DateTime?
  latitude              String?                 @db.VarChar(50)
  longitude             String?                 @db.VarChar(50)
  AthleteStaging        AthleteStaging[]
  athletes              Athlete[]
  EquipmentStaging      EquipmentStaging[]
  equipment             Equipment[]
  facilityRecords       FacilityRecord[]
  FacilityRecordStaging FacilityRecordStaging[]
  kecamatan             Kecamatan               @relation(fields: [kecamatanId], references: [id], onDelete: Cascade)
  SportsGroupStaging    SportsGroupStaging[]
  sportsGroups          SportsGroup[]

  @@index([kecamatanId])
  @@map("m_desa_kelurahan")
}

model CabangOlahraga {
  id                    Int                    @id @default(autoincrement())
  nama                  String                 @db.VarChar(100)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  AthleteStaging        AthleteStaging[]
  athletes              Athlete[]
  sportsGroups          SportsGroup[]
  sportsGroupsStaging   SportsGroupStaging[]   @relation("SportsGroupStagingCabor")

  @@map("m_cabang_olahraga")
}

model Sarana {
  id               Int                @id @default(autoincrement())
  nama             String             @db.VarChar(150)
  jenis            String?            @db.VarChar(100)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?
  EquipmentStaging EquipmentStaging[]
  equipment        Equipment[]

  @@map("m_sarana")
}

model Prasarana {
  id                    Int                     @id @default(autoincrement())
  nama                  String                  @db.VarChar(150)
  jenis                 String?                 @db.VarChar(100)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  deletedAt             DateTime?
  facilityRecords       FacilityRecord[]
  FacilityRecordStaging FacilityRecordStaging[]

  @@map("m_prasarana")
}

model News {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  content     String    @db.LongText
  thumbnail   String?
  author      String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  categoryId  Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  views       Int       @default(0)
  category    Category? @relation(fields: [categoryId], references: [id])
  tags        NewsTag[]

  @@index([categoryId], map: "news_categoryId_fkey")
  @@map("news")
}

model Category {
  id   Int    @id @default(autoincrement())
  name String
  slug String @unique
  news News[]

  @@map("categories")
}

model Tag {
  id   Int       @id @default(autoincrement())
  name String
  news NewsTag[]

  @@map("tags")
}

model NewsTag {
  newsId Int
  tagId  Int
  news   News @relation(fields: [newsId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([newsId, tagId])
  @@index([tagId], map: "news_tags_tagId_fkey")
  @@map("news_tags")
}

model Gallery {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  createdAt   DateTime      @default(now())
  deletedAt   DateTime?
  updatedAt   DateTime      @updatedAt
  items       GalleryItem[]

  @@map("galleries")
}

model GalleryItem {
  id        Int      @id @default(autoincrement())
  galleryId Int
  imageUrl  String
  caption   String?
  createdAt DateTime @default(now())
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([galleryId], map: "gallery_items_galleryId_fkey")
  @@map("gallery_items")
}

model Agenda {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  location    String?
  startDate   DateTime
  endDate     DateTime?
  isAllDay    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  category    String?
  level       String?
  status      String    @default("Active")

  @@map("agendas")
}

model Visitor {
  id         Int      @id @default(autoincrement())
  sessionId  String   @db.VarChar(100)
  ipAddress  String?  @db.VarChar(50)
  userAgent  String?  @db.Text
  page       String   @db.VarChar(255)
  referrer   String?  @db.VarChar(255)
  visitedAt  DateTime @default(now())
  country    String?  @db.VarChar(100)
  city       String?  @db.VarChar(100)
  deviceType String?  @db.VarChar(50)

  @@index([sessionId])
  @@index([visitedAt])
  @@index([page])
  @@map("visitors")
}

model FacilityRecord {
  id              Int                   @id @default(autoincrement())
  desaKelurahanId Int
  prasaranaId     Int
  year            Int
  condition       String?
  ownershipStatus String?
  address         String?
  notes           String?
  isActive        Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  createdBy       String?
  updatedBy       String?
  desaKelurahan   DesaKelurahan         @relation(fields: [desaKelurahanId], references: [id])
  prasarana       Prasarana             @relation(fields: [prasaranaId], references: [id])
  photos          FacilityRecordPhoto[]

  @@index([year])
  @@index([prasaranaId])
  @@index([desaKelurahanId], map: "facility_record_desaKelurahanId_fkey")
  @@map("facility_record")
}

model FacilityRecordPhoto {
  id               Int            @id @default(autoincrement())
  facilityRecordId Int
  fileUrl          String
  fileName         String?
  fileSize         Int?
  mimeType         String?
  photoType        String?
  description      String?
  takenAt          DateTime?
  uploadedAt       DateTime       @default(now())
  uploadedBy       String?
  isPrimary        Boolean        @default(false)
  latitude         Float?
  longitude        Float?
  facilityRecord   FacilityRecord @relation(fields: [facilityRecordId], references: [id])

  @@index([facilityRecordId])
  @@map("facility_record_photo")
}

model Equipment {
  id                Int           @id @default(autoincrement())
  desaKelurahanId   Int
  saranaId          Int
  quantity          Int           @default(0)
  unit              String?       @db.VarChar(50)
  isUsable          Boolean       @default(true)
  isGovernmentGrant Boolean       @default(false)
  year              Int?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?
  desaKelurahan     DesaKelurahan @relation(fields: [desaKelurahanId], references: [id], onDelete: Cascade)
  sarana            Sarana        @relation(fields: [saranaId], references: [id], onDelete: Cascade)

  @@index([desaKelurahanId])
  @@index([saranaId])
  @@index([year])
  @@map("equipments")
}

model SportsGroup {
  id                 Int            @id @default(autoincrement())
  desaKelurahanId    Int
  groupName          String         @db.VarChar(150)
  leaderName         String?        @db.VarChar(150)
  memberCount        Int            @default(0)
  isVerified         Boolean        @default(false)
  decreeNumber       String?        @db.VarChar(100)
  secretariatAddress String?        @db.VarChar(255)
  year               Int?
  sportId            Int?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?
  desaKelurahan      DesaKelurahan  @relation(fields: [desaKelurahanId], references: [id], onDelete: Cascade)
  sport              CabangOlahraga? @relation(fields: [sportId], references: [id])

  @@index([desaKelurahanId])
  @@index([sportId])
  @@index([year])
  @@map("sports_groups")
}

model Athlete {
  id              Int                  @id @default(autoincrement())
  nationalId      String               @unique @db.VarChar(20)
  fullName        String               @db.VarChar(150)
  birthPlace      String?              @db.VarChar(100)
  birthDate       DateTime?
  gender          String?              @db.VarChar(10)
  desaKelurahanId Int
  fullAddress     String?
  organization    String?              @db.VarChar(150)
  category        String?              @db.VarChar(100)
  sportId         Int?
  photoUrl        String?              @db.VarChar(255)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?
  status          String               @default("aktif") @db.VarChar(20)
  achievements    AthleteAchievement[]
  desaKelurahan   DesaKelurahan        @relation(fields: [desaKelurahanId], references: [id], onDelete: Cascade)
  sport           CabangOlahraga?      @relation(fields: [sportId], references: [id])

  @@index([desaKelurahanId])
  @@index([sportId])
  @@map("athletes")
}

model AthleteAchievement {
  id              Int      @id @default(autoincrement())
  athleteId       Int
  achievementName String   @db.VarChar(150)
  category        String?  @db.VarChar(100)
  medal           String?  @db.VarChar(20)
  year            Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  athlete         Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@index([athleteId])
  @@map("athlete_achievements")
}

model Registration {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  password     String
  nip          String
  namaLengkap  String
  noTelepon    String
  jenisAkun    Int
  kecamatanId  Int
  lembagaId    Int?
  status       Int
  verifiedBy   Int
  verifiedAt   DateTime?
  rejectReason String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  docUrl       String
  kecamatan    Kecamatan @relation(fields: [kecamatanId], references: [id])

  @@index([kecamatanId], map: "registrations_kecamatanId_fkey")
  @@map("registrations")
}

model EquipmentStaging {
  id                Int           @id @default(autoincrement())
  desaKelurahanId   Int
  saranaId          Int
  quantity          Int           @default(0)
  unit              String?       @db.VarChar(50)
  isUsable          Boolean       @default(true)
  isGovernmentGrant Boolean       @default(false)
  year              Int?
  actionType        StagingAction
  referenceId       Int?
  status            StagingStatus @default(PENDING)
  submittedBy       String
  reviewedBy        String?
  reviewedAt        DateTime?
  rejectionReason   String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  desaKelurahan     DesaKelurahan @relation(fields: [desaKelurahanId], references: [id])
  sarana            Sarana        @relation(fields: [saranaId], references: [id])

  @@index([status])
  @@index([desaKelurahanId])
  @@index([year])
  @@index([saranaId], map: "equipment_staging_saranaId_fkey")
  @@map("equipment_staging")
}

model FacilityRecordStaging {
  id              Int                          @id @default(autoincrement())
  desaKelurahanId Int
  prasaranaId     Int
  year            Int
  condition       String?
  ownershipStatus String?
  address         String?
  notes           String?
  isActive        Boolean                      @default(true)
  actionType      StagingAction
  referenceId     Int?
  status          StagingStatus                @default(PENDING)
  submittedBy     String
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  photos          FacilityRecordPhotoStaging[]
  desaKelurahan   DesaKelurahan                @relation(fields: [desaKelurahanId], references: [id])
  prasarana       Prasarana                    @relation(fields: [prasaranaId], references: [id])

  @@index([status])
  @@index([desaKelurahanId])
  @@index([year])
  @@index([prasaranaId], map: "facility_record_staging_prasaranaId_fkey")
  @@map("facility_record_staging")
}

model FacilityRecordPhotoStaging {
  id                      Int                   @id @default(autoincrement())
  facilityRecordStagingId Int
  fileUrl                 String
  fileName                String?
  fileSize                Int?
  mimeType                String?
  photoType               String?
  description             String?
  takenAt                 DateTime?
  uploadedBy              String?
  isPrimary               Boolean               @default(false)
  latitude                Float?
  longitude               Float?
  createdAt               DateTime              @default(now())
  facilityRecordStaging   FacilityRecordStaging @relation(fields: [facilityRecordStagingId], references: [id], onDelete: Cascade)

  @@index([facilityRecordStagingId])
  @@map("facility_record_photo_staging")
}

model AthleteStaging {
  id              Int                         @id @default(autoincrement())
  nationalId      String                      @db.VarChar(20)
  fullName        String                      @db.VarChar(150)
  birthPlace      String?                     @db.VarChar(100)
  birthDate       DateTime?
  gender          String?                     @db.VarChar(10)
  desaKelurahanId Int
  fullAddress     String?
  organization    String?                     @db.VarChar(150)
  category        String?                     @db.VarChar(100)
  statusAthlete   String                      @default("aktif")
  sportId         Int?
  photoUrl        String?
  actionType      StagingAction
  referenceId     Int?
  status          StagingStatus               @default(PENDING)
  submittedBy     String
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  achievements    AthleteAchievementStaging[]
  desaKelurahan   DesaKelurahan               @relation(fields: [desaKelurahanId], references: [id])
  sport           CabangOlahraga?             @relation(fields: [sportId], references: [id])

  @@index([status])
  @@index([desaKelurahanId])
  @@index([sportId])
  @@map("athlete_staging")
}

model AthleteAchievementStaging {
  id               Int            @id @default(autoincrement())
  athleteStagingId Int
  achievementName  String
  category         String?
  medal            String?
  year             Int?
  createdAt        DateTime       @default(now())
  athlete          AthleteStaging @relation(fields: [athleteStagingId], references: [id], onDelete: Cascade)

  @@index([athleteStagingId])
  @@map("athlete_achievement_staging")
}

model SportsGroupStaging {
  id                 Int           @id @default(autoincrement())
  desaKelurahanId    Int
  groupName          String
  leaderName         String?
  memberCount        Int           @default(0)
  isVerified         Boolean       @default(false)
  decreeNumber       String?
  secretariatAddress String?
  year               Int?
  sportId            Int?
  actionType         StagingAction
  referenceId        Int?
  status             StagingStatus @default(PENDING)
  submittedBy        String
  reviewedBy         String?
  reviewedAt         DateTime?
  rejectionReason    String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  desaKelurahan      DesaKelurahan @relation(fields: [desaKelurahanId], references: [id])
  sport              CabangOlahraga? @relation("SportsGroupStagingCabor", fields: [sportId], references: [id])

  @@index([status])
  @@index([desaKelurahanId])
  @@index([year])
  @@index([sportId])
  @@map("sports_group_staging")
}

model StagingLog {
  id         Int      @id @default(autoincrement())
  entityType String
  stagingId  Int
  action     String
  actor      String
  note       String?
  createdAt  DateTime @default(now())

  @@index([entityType, stagingId])
  @@map("staging_logs")
}

model HeroSectionConfig {
  id             Int      @id @default(autoincrement())
  title          String   @db.VarChar(255)
  description    String   @db.Text
  bannerImageUrl String   @db.VarChar(500)
  displayOrder   Int      @default(0)
  status         Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([displayOrder])
  @@map("hero_section_configs")
}

enum StagingStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StagingAction {
  CREATE
  UPDATE
  DELETE
}
